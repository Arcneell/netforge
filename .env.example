# ----------------------------------------------------------------------------
# Netforge — variables d'environnement
# Copier en .env et remplir les valeurs. .env n'est PAS versionné.
# ----------------------------------------------------------------------------

# URL publique utilisée pour construire les redirect URIs OIDC
PUBLIC_URL=https://netforge.example.local

# PostgreSQL (utilisé par le container postgres ET par le backend)
POSTGRES_DB=netforge
POSTGRES_USER=netforge
POSTGRES_PASSWORD=change-me-generate-a-32-char-random

# DATABASE_URL utilisée par le backend. En dev hors docker, remplacer "postgres" par "localhost".
DATABASE_URL=postgresql+asyncpg://netforge:change-me-generate-a-32-char-random@postgres:5432/netforge

# Entra ID (voir docs/06-auth.md)
ENTRA_TENANT_ID=00000000-0000-0000-0000-000000000000
ENTRA_CLIENT_ID=00000000-0000-0000-0000-000000000000
ENTRA_CLIENT_SECRET=change-me

# Clé de signature des cookies de session. Générer avec: openssl rand -hex 32
SESSION_SIGNING_KEY=change-me

# Premier email qui se connecte devient admin automatiquement
BOOTSTRAP_ADMIN_EMAIL=admin@example.com

# Niveau de log backend (debug, info, warning, error)
LOG_LEVEL=info

# Origines autorisées en CORS (dev). En prod, laisser vide: tout passe par le reverse proxy nginx.
CORS_ORIGINS=http://localhost:5173
