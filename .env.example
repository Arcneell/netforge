# ----------------------------------------------------------------------------
# Netforge — environment variables
# Copy this file to .env and fill in the values. .env is NOT version-controlled.
# ----------------------------------------------------------------------------

# Public URL used to build OIDC redirect URIs
PUBLIC_URL=https://netforge.example.local

# PostgreSQL (used by the postgres container AND by the backend)
POSTGRES_DB=netforge
POSTGRES_USER=netforge
POSTGRES_PASSWORD=change-me-generate-a-32-char-random

# DATABASE_URL consumed by the backend. For local dev outside Docker, replace "postgres" with "localhost".
DATABASE_URL=postgresql+asyncpg://netforge:change-me-generate-a-32-char-random@postgres:5432/netforge

# Entra ID (see docs/06-auth.md)
ENTRA_TENANT_ID=00000000-0000-0000-0000-000000000000
ENTRA_CLIENT_ID=00000000-0000-0000-0000-000000000000
ENTRA_CLIENT_SECRET=change-me

# Session cookie signing key. Generate with: openssl rand -hex 32
SESSION_SIGNING_KEY=change-me

# The first email to log in is automatically promoted to admin
BOOTSTRAP_ADMIN_EMAIL=admin@example.com

# Backend log level (debug, info, warning, error)
LOG_LEVEL=info

# Allowed CORS origins (dev only). In production leave empty: everything goes through the nginx reverse proxy.
CORS_ORIGINS=http://localhost:5173
